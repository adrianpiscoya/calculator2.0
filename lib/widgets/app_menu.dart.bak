// lib/widgets/app_menu.dart
import 'dart:async';
import 'package:flutter/foundation.dart';
import 'package:flutter/material.dart';
import 'package:flutter/services.dart';
import 'package:provider/provider.dart';
import 'package:shared_preferences/shared_preferences.dart';
import '../theme_provider.dart';
import '../widgets/banner_ad_widget.dart';
import '../widgets/asset_button.dart';
import '../screens/basic_calculator.dart';
import '../scientific_calculator.dart';
import '../screens/guess_game.dart';
import '../screens/function_graph.dart';
import '../screens/statistics_screen.dart';
import '../screens/exchange_screen.dart';
import '../screens/unit_converter_screen.dart';
import '../screens/suggestions_screen.dart';
import '../screens/help_screen.dart';

/// Muestra la hoja inferior con el menú de la aplicación.
void showAppMenu(BuildContext context) {
  showModalBottomSheet(
    context: context,
    isScrollControlled: true,
    backgroundColor: Colors.transparent,
    builder: (ctx) {
      return Consumer<ThemeProvider>(builder: (ctx, theme, _) {
        return AppMenuContent(theme: theme, parentContext: ctx);
      });
    },
  );
}

class AppMenuContent extends StatefulWidget {
  final ThemeProvider theme;
  final BuildContext parentContext;

  const AppMenuContent({Key? key, required this.theme, required this.parentContext}) : super(key: key);

  @override
  State<AppMenuContent> createState() => _AppMenuContentState();
}

class _AppMenuContentState extends State<AppMenuContent> with SingleTickerProviderStateMixin {
  Color _withAlpha(Color c, double factor) {
    final a = (factor * 255).round().clamp(0, 255);
    return Color.fromARGB(a, c.red, c.green, c.blue);
  }

  late final AnimationController _anim;
  late final List<Widget Function(ThemeProvider)> _menuBuilders;

  @override
  void initState() {
    super.initState();
    _anim = AnimationController(vsync: this, duration: const Duration(milliseconds: 260))..forward();
    _menuBuilders = _createMenuBuilders();
  }

  List<Widget Function(ThemeProvider)> _createMenuBuilders() {
    return [
      (theme) => _buildHeader(theme),
      (theme) => const SizedBox(height: 8),
      (theme) => _sectionHeader(theme, 'Calculadoras'),
      (theme) => const Divider(thickness: 1, height: 8),
      (theme) => _menuTile(
            icon: Icons.calculate,
            label: 'De bolsillo',
            subtitle: 'Calculadora básica y rápida',
            onTap: () {
              _selectAndNavigate(() async {
                Navigator.push(widget.parentContext, MaterialPageRoute(builder: (_) => const BasicCalculatorScreen()));
              });
            },
            theme: theme,
          ),
      (theme) => _menuTile(
            icon: Icons.science,
            label: 'Científica',
            subtitle: 'Funciones, trigonometría y más',
            onTap: () {
              _selectAndNavigate(() async {
                Navigator.push(widget.parentContext, MaterialPageRoute(builder: (_) => const ScientificCalculator()));
              });
            },
            theme: theme,
          ),
      (theme) => const SizedBox(height: 10),
      (theme) => _sectionHeader(theme, 'Herramientas'),
      (theme) => const Divider(thickness: 1, height: 8),
      (theme) => _menuTile(
            icon: Icons.videogame_asset,
            label: 'Game',
            subtitle: 'Juego rápido para practicar',
            onTap: () {
              _selectAndNavigate(() async {
                Navigator.push(widget.parentContext, MaterialPageRoute(builder: (_) => GameScreen()));
              });
            },
            theme: theme,
          ),
      (theme) => _menuTile(
            icon: Icons.show_chart,
            label: 'Graficar función',
            subtitle: 'Funciones matemáticas y visualización',
            onTap: () {
              _selectAndNavigate(() async {
                Navigator.push(widget.parentContext, MaterialPageRoute(builder: (_) => FunctionGraph()));
              });
            },
            theme: theme,
          ),
      (theme) => _menuTile(
            icon: Icons.bar_chart,
            label: 'Estadísticas',
            subtitle: 'Análisis y resumen de datos',
            onTap: () {
              _selectAndNavigate(() async {
                Navigator.push(widget.parentContext, MaterialPageRoute(builder: (_) => StatisticsScreen()));
              });
            },
            theme: theme,
          ),
      (theme) => _menuTile(
            icon: Icons.attach_money,
            label: 'Divisas',
            subtitle: 'Convertidor de monedas',
            onTap: () {
              _selectAndNavigate(() async {
                Navigator.push(widget.parentContext, MaterialPageRoute(builder: (_) => ExchangeScreen()));
              });
            },
            theme: theme,
          ),
      (theme) => _menuTile(
            icon: Icons.swap_horiz,
            label: 'Conversor de Unidades',
            subtitle: 'Metros, kg, velocidad y más',
            onTap: () {
              _selectAndNavigate(() async {
                Navigator.push(widget.parentContext, MaterialPageRoute(builder: (_) => UnitConverterScreen()));
              });
            },
            theme: theme,
          ),
      (theme) => const SizedBox(height: 10),
      (theme) => _sectionHeader(theme, 'Ajustes'),
      (theme) => const Divider(thickness: 1, height: 8),
      (theme) => SwitchListTile(
            secondary: Icon(Icons.dark_mode, color: theme.accentColor),
            title: Text('Modo oscuro', style: TextStyle(color: theme.displayTextColor, fontWeight: FontWeight.w700)),
            value: theme.isDark,
            onChanged: (v) => theme.setDark(v),
          ),
      (theme) => _menuTile(
            icon: Icons.feedback,
            label: 'Sugerencias',
            subtitle: null,
            onTap: () {
              _selectAndNavigate(() async {
                Navigator.push(widget.parentContext, MaterialPageRoute(builder: (_) => const SuggestionsScreen()));
              });
            },
            theme: theme,
          ),
      (theme) => _menuTile(
            icon: Icons.help_outline,
            label: 'Ayuda',
            subtitle: null,
            onTap: () {
              _selectAndNavigate(() async {
                Navigator.push(widget.parentContext, MaterialPageRoute(builder: (_) => const HelpScreen()));
              });
            },
            theme: theme,
          ),
      (theme) => const SizedBox(height: 12),
      (theme) => _clearCacheTile(theme),
      // Cargamos el banner con retraso para no bloquear la apertura
      (theme) => FutureBuilder<void>(
            future: Future.delayed(const Duration(milliseconds: 600)),
            builder: (context, snap) {
              if (snap.connectionState != ConnectionState.done) return const SizedBox(height: 56);
              return const Center(child: BannerAdWidget());
            },
          ),
    ];
  }

  Widget _buildHeader(ThemeProvider theme) {
    return Padding(
      padding: const EdgeInsets.symmetric(vertical: 8.0),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              CircleAvatar(
                radius: 22,
                backgroundColor: theme.accentColor.withAlpha((0.12 * 255).round()),
                child: Icon(Icons.calculate, color: theme.accentColor),
              ),
              const SizedBox(width: 12),
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text('Menú de la aplicación', style: TextStyle(fontSize: 18 * theme.fontScale, fontWeight: FontWeight.bold, color: theme.displayTextColor)),
                    const SizedBox(height: 2),
                    Text('v1.0.0', style: TextStyle(color: theme.displayTextColor.withAlpha((0.7 * 255).round()), fontSize: 12 * theme.fontScale)),
                  ],
                ),
              ),
            ],
          ),
          const SizedBox(height: 12),
          SizedBox(
            height: 44,
            child: ListView(
              scrollDirection: Axis.horizontal,
              children: [
                const SizedBox(width: 4),
                _quickActionChip(icon: Icons.history, label: 'Historial', onTap: () => _openHistoryFromParent(), theme: theme),
                _quickActionChip(icon: Icons.favorite, label: 'Favoritos', onTap: () => _openFavoritesDialog(), theme: theme),
                _quickActionChip(icon: Icons.delete, label: 'Limpiar', onTap: () {
                  AssetButton.clearSanitizedCache();
                  ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text('Caché SVG vaciada')));
                }, theme: theme),
                _quickActionChip(icon: Icons.help_outline, label: 'Ayuda', onTap: () {
                  _selectAndNavigate(() async {
                    Navigator.push(widget.parentContext, MaterialPageRoute(builder: (_) => const HelpScreen()));
                  });
                }, theme: theme),
                const SizedBox(width: 8),
              ],
            ),
          ),
        ],
      ),
    );
  }

  Widget _sectionHeader(ThemeProvider theme, String title) {
    return Padding(
      padding: const EdgeInsets.symmetric(vertical: 6.0),
      child: Text(title, style: TextStyle(color: theme.accentColor, fontFamily: 'RobotoMono', fontWeight: FontWeight.w900, fontSize: 16 * theme.fontScale)),
    );
  }

  Widget _clearCacheTile(ThemeProvider theme) {
    return ListTile(
      leading: Icon(Icons.delete_forever, color: theme.accentColor),
      title: Text('Vaciar caché SVG', style: TextStyle(color: theme.displayTextColor, fontWeight: FontWeight.w700)),
      subtitle: Text('Forzar recarga de assets SVG', style: TextStyle(color: theme.isDark ? Colors.white70 : Colors.black, fontSize: 12 * theme.fontScale)),
      onTap: () {
        try {
          AssetButton.clearSanitizedCache();
          ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text('Caché SVG vaciada')));
        } catch (_) {
          ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text('No se pudo vaciar la caché')));
        }
      },
    );
  }

  @override
  void dispose() {
    _anim.dispose();
    super.dispose();
  }

  Future<void> _closeWithAnimation() async {
    await _anim.reverse();
    if (Navigator.of(context).canPop()) Navigator.of(context).pop();
  }

  Future<void> _selectAndNavigate(Future<void> Function() nav) async {
    _anim.reverse();
    if (Navigator.of(context).canPop()) Navigator.of(context).pop();
    // activamos navegación sin bloquear la UI
    Future.microtask(() => nav());
  }

  Future<void> _openHistoryFromParent() async {
    try {
      final prefs = await SharedPreferences.getInstance();
      final history = prefs.getStringList('conversion_history') ?? [];
      if (!mounted) return;
      showDialog(
        context: context,
        builder: (_) => AlertDialog(
          title: const Text('Historial'),
          content: SizedBox(
            width: double.maxFinite,
            child: history.isEmpty ? const Text('No hay elementos en el historial') : ListView(shrinkWrap: true, children: history.map((e) => Text(e)).toList()),
          ),
          actions: [TextButton(onPressed: () => Navigator.pop(context), child: const Text('Cerrar'))],
        ),
      );
    } catch (_) {
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text('No disponible')));
    }
  }

  Future<void> _openFavoritesDialog() async {
    try {
      final prefs = await SharedPreferences.getInstance();
      final favs = prefs.getStringList('favorites') ?? [];
      if (!mounted) return;
      showDialog(
        context: context,
        builder: (_) => AlertDialog(
          title: const Text('Favoritos'),
          content: SizedBox(width: double.maxFinite, child: favs.isEmpty ? const Text('No hay favoritos guardados') : ListView(shrinkWrap: true, children: favs.map((e) => ListTile(title: Text(e))).toList())),
          actions: [
            TextButton(onPressed: () => Navigator.pop(context), child: const Text('Cerrar')),
            if (favs.isNotEmpty)
              TextButton(
                onPressed: () async {
                  await prefs.remove('favorites');
                  if (!mounted) return;
                  Navigator.pop(context);
                  ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text('Favoritos borrados')));
                },
                child: const Text('Borrar todos'),
              )
          ],
        ),
      );
    } catch (_) {
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text('No disponible')));
    }
  }

  @override
  Widget build(BuildContext context) {
    final theme = widget.theme;
    return DraggableScrollableSheet(
      initialChildSize: 0.9,
      minChildSize: 0.5,
      maxChildSize: 0.95,
      builder: (_, controller) {
        return FadeTransition(
          opacity: CurvedAnimation(parent: _anim, curve: Curves.easeOut),
          child: ScaleTransition(
            scale: Tween<double>(begin: 0.985, end: 1.0).animate(CurvedAnimation(parent: _anim, curve: Curves.easeOut)),
            child: GestureDetector(
              onVerticalDragEnd: (details) {
                if (details.primaryVelocity != null && details.primaryVelocity! > 400) {
                  _closeWithAnimation();
                }
              },
              child: Container(
                padding: const EdgeInsets.all(14),
                decoration: BoxDecoration(
                  color: theme.displayColor,
                  borderRadius: const BorderRadius.vertical(top: Radius.circular(16)),
                  boxShadow: [BoxShadow(color: _withAlpha(Colors.black, 0.18), blurRadius: 12, offset: const Offset(0, -4))],
                ),
                child: Column(
                  children: [
                    Row(
                      children: [
                        Expanded(
                          child: Center(
                            child: Container(width: 44, height: 5, decoration: BoxDecoration(color: _withAlpha(theme.displayTextColor, 0.14), borderRadius: BorderRadius.circular(6))),
                          ),
                        ),
                        IconButton(icon: Icon(Icons.close, color: theme.displayTextColor), onPressed: _closeWithAnimation, tooltip: 'Cerrar'),
                      ],
                    ),
                    Expanded(
                      child: FutureBuilder<void>(
                        future: Future.delayed(const Duration(milliseconds: 100)), // pequeño warm-up
                        builder: (context, snap) {
                          if (snap.connectionState != ConnectionState.done) {
                            return const SizedBox.shrink();
                          }

                          return ListView.builder(
                            controller: controller,
                            padding: EdgeInsets.zero,
                            itemCount: _menuBuilders.length,
                            itemBuilder: (context, index) {
                              final builder = _menuBuilders[index];
                              return builder(theme);
                            },
                          );
                        },
                      ),
                    ),
                  ],
                ),
              ),
            ),
          ),
        );
      },
    );
  }

  Widget _menuTile({required IconData icon, required String label, String? subtitle, required VoidCallback onTap, required ThemeProvider theme}) {
    return RepaintBoundary(
      child: ListTile(
        leading: Icon(icon, color: theme.accentColor),
        title: Text(label, style: TextStyle(color: theme.displayTextColor, fontWeight: FontWeight.w700, fontSize: 14 * theme.fontScale)),
        subtitle: subtitle != null ? Text(subtitle, style: TextStyle(color: _withAlpha(theme.displayTextColor, theme.isDark ? 0.85 : 0.9), fontSize: 12 * theme.fontScale)) : null,
        onTap: onTap,
        contentPadding: const EdgeInsets.symmetric(horizontal: 4.0, vertical: 2.0),
        visualDensity: VisualDensity.compact,
        minVerticalPadding: 4,
      ),
    );
  }

  Widget _quickActionChip({required IconData icon, required String label, required VoidCallback onTap, required ThemeProvider theme}) {
    return _AnimatedActionChip(icon: icon, label: label, onTap: onTap, theme: theme);
  }
}

class _AnimatedActionChip extends StatefulWidget {
  final IconData icon;
  final String label;
  final VoidCallback onTap;
  final ThemeProvider theme;

  const _AnimatedActionChip({Key? key, required this.icon, required this.label, required this.onTap, required this.theme}) : super(key: key);

  @override
  State<_AnimatedActionChip> createState() => _AnimatedActionChipState();
}

class _AnimatedActionChipState extends State<_AnimatedActionChip> {
  bool _pressed = false;

  void _handleTap() {
    try {
      HapticFeedback.selectionClick();
    } catch (_) {}
    widget.onTap();
  }

  @override
  Widget build(BuildContext context) {
    final theme = widget.theme;
    return Padding(
      padding: const EdgeInsets.symmetric(horizontal: 6.0),
      child: Semantics(
        button: true,
        label: widget.label,
        child: Tooltip(
          message: widget.label,
          child: GestureDetector(
            onTapDown: (_) => setState(() => _pressed = true),
            onTapUp: (_) => setState(() => _pressed = false),
            onTapCancel: () => setState(() => _pressed = false),
            child: AnimatedScale(
              scale: _pressed ? 0.96 : 1.0,
              duration: const Duration(milliseconds: 120),
              curve: Curves.easeOut,
              child: Material(
                color: theme.displayColor,
                shape: const StadiumBorder(),
                child: InkWell(
                  customBorder: const StadiumBorder(),
                  onTap: _handleTap,
                  child: Container(
                    padding: const EdgeInsets.symmetric(horizontal: 12.0, vertical: 8.0),
                    child: Row(
                      mainAxisSize: MainAxisSize.min,
                      children: [
                        Icon(widget.icon, size: 18, color: theme.displayTextColor),
                        const SizedBox(width: 8),
                        Text(widget.label, style: TextStyle(color: theme.displayTextColor, fontSize: 13 * theme.fontScale)),
                      ],
                    ),
                  ),
                ),
              ),
            ),
          ),
        ),
      ),
    );
  }
}
