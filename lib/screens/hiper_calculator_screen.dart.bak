                        style: TextStyle(
                          color: Colors.white70,
                          fontSize: 16,
                        ),
                      ),
                      SizedBox(height: 8),
                      Text(
                        'Modo: ${_selectedMode == 0 ? "BГЎsico" : _selectedMode == 1 ? "TrigonomГ©trico" : _selectedMode == 2 ? "Avanzado" : _selectedMode == 3 ? "Constantes" : "Fracciones"}',
                        style: TextStyle(
                          color: Colors.white60,
                          fontSize: 12,
                        ),
                      ),
                    ],
                  ),
                ),

                // SECCIГ“N: MODOS DE CALCULADORA
                Padding(
                  padding: EdgeInsets.symmetric(horizontal: 16, vertical: 8),
