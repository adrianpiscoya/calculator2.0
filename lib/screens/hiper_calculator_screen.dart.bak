                  title: Text('NГєmero e'),
                  subtitle: Text('2.71828...'),
                  onTap: () {
                    Navigator.pop(context);
                    _expression += 'e';
                    setState(() {});
                  },
                ),
                ListTile(
                  leading: Icon(Icons.swap_horiz, color: Colors.orange[700]),
                  title: Text('Decimal в†” FracciГіn'),
                  subtitle: Text('Convertir entre formatos'),
                  onTap: () {
                    Navigator.pop(context);
                    if (_result.isNotEmpty && _result != 'Error') {
                      try {
                        double value = double.parse(_result);
                        String fractionResult = _decimalToFraction(value);
                        _result = fractionResult;
                        setState(() {});
                      } catch (e) {
                        ScaffoldMessenger.of(context).showSnackBar(
                          SnackBar(content: Text('No se puede convertir')),
                        );
                      }
                    }
                  },
                ),

                Divider(),

                // SECCIГ“N: CONFIGURACIГ“N
                Padding(
                  padding: EdgeInsets.symmetric(horizontal: 16, vertical: 8),
                  child: Text('CONFIGURACIГ“N',
                      style: TextStyle(
                          fontSize: 12,
                          fontWeight: FontWeight.bold,
                          color: Colors.grey[600])),
                ),
                ListTile(
                  leading: Icon(Icons.rotate_right, color: Colors.blue[700]),
                  title: Text('Modo ГЃngulo: $_angleMode'),
                  subtitle: Text('RAD / DEG / GRAD'),
                  onTap: () {
                    Navigator.pop(context);
                    setState(() {
                      if (_angleMode == 'RAD') {
                        _angleMode = 'DEG';
                      } else if (_angleMode == 'DEG') {
                        _angleMode = 'GRAD';
                      } else {
                        _angleMode = 'RAD';
                      }
                    });
                  },
                ),
                ListTile(
                  leading:
                      Icon(Icons.format_list_numbered, color: Colors.blue[700]),
                  title: Text('Formato: $_numberFormat'),
                  subtitle: Text('NORMAL / SCI / ENG'),
                  onTap: () {
                    Navigator.pop(context);
                    setState(() {
                      if (_numberFormat == 'NORMAL') {
                        _numberFormat = 'SCI';
                      } else if (_numberFormat == 'SCI') {
                        _numberFormat = 'ENG';
                      } else {
                        _numberFormat = 'NORMAL';
                      }
                    });
                  },
                ),

                Divider(),

                // SECCIГ“N: MГ“DULOS ADICIONALES
                Padding(
                  padding: EdgeInsets.symmetric(horizontal: 16, vertical: 8),
                  child: Text('MГ“DULOS',
                      style: TextStyle(
                          fontSize: 12,
                          fontWeight: FontWeight.bold,
                          color: Colors.grey[600])),
