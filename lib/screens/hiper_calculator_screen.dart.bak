                  leading: Icon(Icons.calculate, color: Colors.blue[700]),
                  title: Text('BГЎsico'),
                  trailing: _selectedMode == 0
                      ? Icon(Icons.check, color: Colors.green)
                      : null,
                  onTap: () {
                    Navigator.pop(context);
                    setState(() {
                      _selectedMode = 0;
                    });
                  },
                ),
                ListTile(
                  leading: Icon(Icons.functions, color: Colors.orange[700]),
                  title: Text('TrigonomГ©trico'),
                  trailing: _selectedMode == 1
                      ? Icon(Icons.check, color: Colors.green)
                      : null,
                  onTap: () {
                    Navigator.pop(context);
                    setState(() {
                      _selectedMode = 1;
                    });
                  },
                ),
                ListTile(
                  leading: Icon(Icons.science, color: Colors.purple[700]),
                  title: Text('Avanzado'),
                  trailing: _selectedMode == 2
                      ? Icon(Icons.check, color: Colors.green)
                      : null,
                  onTap: () {
                    Navigator.pop(context);
                    setState(() {
                      _selectedMode = 2;
                    });
                  },
                ),
                ListTile(
                  leading: Icon(Icons.code, color: Colors.indigo[700]),
                  title: Text('Constantes'),
                  trailing: _selectedMode == 3
                      ? Icon(Icons.check, color: Colors.green)
                      : null,
                  onTap: () {
                    Navigator.pop(context);
                    setState(() {
                      _selectedMode = 3;
                    });
                  },
                ),
                ListTile(
                  leading: Icon(Icons.pie_chart, color: Colors.pink[700]),
                  title: Text('Fracciones'),
                  trailing: _selectedMode == 4
                      ? Icon(Icons.check, color: Colors.green)
                      : null,
                  onTap: () {
                    Navigator.pop(context);
                    setState(() {
                      _selectedMode = 4;
                    });
                  },
                ),

                Divider(),

                // SECCIГ“N: FUNCIONES RГЃPIDAS
                Padding(
                  padding: EdgeInsets.symmetric(horizontal: 16, vertical: 8),
                  child: Text('FUNCIONES RГЃPIDAS',
                      style: TextStyle(
                          fontSize: 12,
                          fontWeight: FontWeight.bold,
                          color: Colors.grey[600])),
                ),
                ListTile(
                  leading: Icon(Icons.square_foot, color: Colors.green[700]),
                  title: Text('RaГ­z Cuadrada'),
                  subtitle: Text('в€љ'),
                  onTap: () {
                    Navigator.pop(context);
                    _expression += 'в€љ(';
                    _optimizedSetState();
                  },
                ),
                ListTile(
                  leading: Icon(Icons.change_circle, color: Colors.green[700]),
                  title: Text('Pi (ПЂ)'),
                  subtitle: Text('3.14159...'),
