  // MГ©todo auxiliar para verificar si es dГ­gito o punto
  bool _isDigitOrDot(String text) {
    return '0123456789.'.contains(text);
  }

  // OPTIMIZACIГ“N: Formatear expresiГіn con cachГ© para mejor rendimiento
  String _formatExpression(String expression) {
    // Usar cachГ© para evitar RegExp costosas repetidas
    if (_formatCache.containsKey(expression)) {
      return _formatCache[expression]!;
    }

    String formatted = expression;

    // OPTIMIZACIГ“N: Usar reemplazos simples en lugar de RegExp cuando sea posible
    formatted = formatted.replaceAll('*', ' Г— ');
    formatted = formatted.replaceAll('+', ' + ');
    formatted = formatted.replaceAll('-', ' - ');
    formatted = formatted.replaceAll('^', '^');
    formatted = formatted.replaceAll('sqrt', 'в€љ');
    formatted = formatted.replaceAll('pi', 'ПЂ');

    // Solo usar RegExp para casos especГ­ficos complejos
    formatted = formatted.replaceAllMapped(
      RegExp(r'(?<!\()(\d+|\w+)\s*/\s*(?!\d+\))'),
      (match) => '${match.group(1)} Г· ',
    );

    // Guardar en cachГ© con lГ­mite de tamaГ±o
    if (_formatCache.length >= _maxCacheSize) {
      _formatCache.clear(); // Limpiar cachГ© si estГЎ lleno
    }
    _formatCache[expression] = formatted;

    return formatted;
  }

  // Widget de display unificado (expresiГіn + resultado en uno)
  Widget _buildUnifiedDisplay() {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.end,
      children: [
        // ExpresiГіn anterior/histГіrico (parte superior pequeГ±a)
        if (_expression.isNotEmpty)
          Container(
            width: double.infinity,
            child: SingleChildScrollView(
              scrollDirection: Axis.horizontal,
              reverse: true,
              child: Text(
                _formatExpression(_expression),
                style: TextStyle(
                  fontSize: 16,
                  color: Colors.grey[400],
                  fontFamily: 'RobotoMono',
                ),
                textAlign: TextAlign.right,
              ),
            ),
          ),

        SizedBox(height: 8),

        // Resultado principal (grande, en la parte inferior)
        Expanded(
          child: Container(
            width: double.infinity,
            child: SingleChildScrollView(
              scrollDirection: Axis.horizontal,
              reverse: true,
              child: Align(
                alignment: Alignment.centerRight,
                child: Text(
                  _result.isEmpty ? '0' : _result,
                  style: TextStyle(
                    fontSize: 42, // MГЎs grande al tener mГЎs espacio
                    fontWeight: FontWeight.bold,
                    color: _result == 'Error' ? Colors.red[400] : Colors.white,
                    fontFamily: 'RobotoMono',
                  ),
                ),
              ),
            ),
          ),
        ),
      ],
    );
  }

