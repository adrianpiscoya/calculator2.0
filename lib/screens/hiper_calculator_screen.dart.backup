                Spacer(),
                // Indicador de formato de número (clickeable)
                GestureDetector(
                  onTap: () {
                    // Cambiar formato de número
                    if (_numberFormat == 'NORMAL') {
                      _numberFormat = 'SCI';
                    } else if (_numberFormat == 'SCI') {
