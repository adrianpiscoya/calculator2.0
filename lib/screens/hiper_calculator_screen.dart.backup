                            String expression = _history[index].split(' = ')[0];
                            _expression = expression;
                            setState(() {});
                            Navigator.pop(context);
                          },
                        );
                      },
                    ),
                  ),
                  actions: [
                    TextButton(
                      onPressed: () => Navigator.pop(context),
                      child: Text('Cerrar'),
                    ),
                  ],
                ),
              );
            },
          ),
        ],
