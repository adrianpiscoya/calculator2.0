          ),
        ],
      ),
    );
  }

  // Método auxiliar para verificar si es dígito o punto
  bool _isDigitOrDot(String text) {
    return '0123456789.'.contains(text);
  }

  // OPTIMIZACIÓN: Formatear expresión con caché para mejor rendimiento
  String _formatExpression(String expression) {
    // Usar caché para evitar RegExp costosas repetidas
    if (_formatCache.containsKey(expression)) {
      return _formatCache[expression]!;
    }

    String formatted = expression;

    // OPTIMIZACIÓN: Usar reemplazos simples en lugar de RegExp cuando sea posible
    formatted = formatted.replaceAll('*', ' × ');
    formatted = formatted.replaceAll('+', ' + ');
    formatted = formatted.replaceAll('-', ' - ');
    formatted = formatted.replaceAll('^', '^');
    formatted = formatted.replaceAll('sqrt', '√');
    formatted = formatted.replaceAll('pi', 'π');

    // Solo usar RegExp para casos específicos complejos
    formatted = formatted.replaceAllMapped(
      RegExp(r'(?<!\()(\d+|\w+)\s*/\s*(?!\d+\))'),
      (match) => '${match.group(1)} ÷ ',
    );

    // Guardar en caché con límite de tamaño
    if (_formatCache.length >= _maxCacheSize) {
      _formatCache.clear(); // Limpiar caché si está lleno
    }
    _formatCache[expression] = formatted;

    return formatted;
  }

  // Widget de display unificado (expresión + resultado en uno)
  Widget _buildUnifiedDisplay() {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.end,
      children: [
        // Expresión anterior/histórico (parte superior pequeña)
        if (_expression.isNotEmpty)
          Container(
            width: double.infinity,
            child: SingleChildScrollView(
              scrollDirection: Axis.horizontal,
              reverse: true,
              child: Text(
                _formatExpression(_expression),
                style: TextStyle(
                  fontSize: 16,
                  color: Colors.grey[400],
                  fontFamily: 'RobotoMono',
                ),
                textAlign: TextAlign.right,
              ),
            ),
          ),

        SizedBox(height: 8),

        // Resultado principal (grande, en la parte inferior)
        Expanded(
          child: Container(
            width: double.infinity,
            child: SingleChildScrollView(
              scrollDirection: Axis.horizontal,
              reverse: true,
              child: Align(
                alignment: Alignment.centerRight,
                child: Text(
                  _result.isEmpty ? '0' : _result,
                  style: TextStyle(
                    fontSize: 42, // Más grande al tener más espacio
                    fontWeight: FontWeight.bold,
                    color: _result == 'Error' ? Colors.red[400] : Colors.white,
                    fontFamily: 'RobotoMono',
                  ),
                ),
              ),
            ),
          ),
        ),
      ],
    );
  }

